# Backend Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Change this to a long random secret string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here

# REQUIRED in production: Render PostgreSQL URL (set automatically if you link the DB on Render)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Set to False in production
FLASK_DEBUG=False

# REQUIRED: Your Vercel frontend URL (e.g. https://leadiq.vercel.app)
# Use * to allow all origins (not recommended for production)
FRONTEND_URL=https://your-app.vercel.app
